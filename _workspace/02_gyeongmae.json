{
  "version": "1.1",
  "track": "gyeongmae",
  "track_label": "경매 투자성향",
  "code_prefix": "A-",
  "axis_order": ["FUND", "DIFFICULTY", "REGION", "PURPOSE"],

  "axes": [
    {
      "id": "FUND",
      "label": "자금 전략",
      "pole_a": { "code": "s", "label": "소액분산형", "desc": "소액·다건·대출 활용, 리스크 분산" },
      "pole_b": { "code": "b", "label": "대액집중형", "desc": "큰 자금을 소수 핵심 물건에 집중" },
      "default_pole": "s"
    },
    {
      "id": "DIFFICULTY",
      "label": "물건 난이도",
      "pole_a": { "code": "c", "label": "안전입찰형", "desc": "권리 단순·명도 수월, 경쟁 많아 낙찰가율↑" },
      "pole_b": { "code": "x", "label": "특수물건형", "desc": "유치권·지상권·지분 등 고난도, 싸게 낙찰·소송/명도 역량 필요" },
      "default_pole": "c"
    },
    {
      "id": "REGION",
      "label": "지역 전략",
      "pole_a": { "code": "n", "label": "연고지집중형", "desc": "익숙한 생활권·연고지의 시세·임차수요 우위" },
      "pole_b": { "code": "w", "label": "전국추적형", "desc": "수익률을 따라 전국 어디든 추적" },
      "default_pole": "n"
    },
    {
      "id": "PURPOSE",
      "label": "용도 지향",
      "pole_a": { "code": "r", "label": "실수요·보유형", "desc": "낙찰 후 실거주·장기임대로 보유" },
      "pole_b": { "code": "f", "label": "단기매각형", "desc": "명도·수리 후 빠르게 되팔아 차익 실현" },
      "default_pole": "r"
    }
  ],

  "questions": [
    {
      "id": "g1",
      "axis": "FUND",
      "text": "경매 자금 운용 스타일에 더 가까운 것은?",
      "options": [
        { "label": "소액으로 여러 건에 나눠 담는다", "score": { "s": 2 } },
        { "label": "큰 자금을 소수 우량 물건에 집중한다", "score": { "b": 2 } }
      ]
    },
    {
      "id": "g2",
      "axis": "FUND",
      "text": "한 건이 잘못됐을 때를 떠올리면, 당신은?",
      "options": [
        { "label": "분산해서 한 건 실패의 타격을 줄이고 싶다", "score": { "s": 2 } },
        { "label": "집중해서 건당 임팩트·협상력을 키우고 싶다", "score": { "b": 2 } }
      ]
    },

    {
      "id": "g3",
      "axis": "DIFFICULTY",
      "text": "두 물건 중 더 끌리는 쪽은?",
      "options": [
        { "label": "경쟁이 붙어도 권리 깨끗하고 명도 쉬운 물건", "score": { "c": 2 } },
        { "label": "아무도 안 들어와 싸게 받는 복잡한(유치권·지분 등) 물건", "score": { "x": 2 } }
      ]
    },
    {
      "id": "g4",
      "axis": "DIFFICULTY",
      "text": "유치권·법정지상권·지분 같은 특수물건 입찰에 대해?",
      "options": [
        { "label": "분석·소송 부담이 커서 피한다", "score": { "c": 2 } },
        { "label": "마진이 크니 적극 도전한다", "score": { "x": 2 } }
      ]
    },
    {
      "id": "g5",
      "axis": "DIFFICULTY",
      "text": "낙찰 후 점유자와 명도 분쟁이 생긴다면?",
      "options": [
        { "label": "그런 분쟁은 최대한 피하고 싶다", "score": { "c": 2 } },
        { "label": "어느 정도의 분쟁·협상은 감수할 수 있다", "score": { "x": 2 } }
      ]
    },

    {
      "id": "g6",
      "axis": "REGION",
      "text": "잘 모르는 지방에 수익률 좋은 물건이 나왔습니다. 당신은?",
      "options": [
        { "label": "수익이 좋으면 멀어도 추적해 간다", "score": { "w": 2 } },
        { "label": "잘 아는 동네의 평타 물건이 마음 편하다", "score": { "n": 2 } }
      ]
    },
    {
      "id": "g7",
      "axis": "REGION",
      "text": "임장(현장조사)·명도·관리에 드는 거리/시간을 생각하면?",
      "options": [
        { "label": "익숙한 지역이라 발품·관리가 수월한 게 좋다", "score": { "n": 2 } },
        { "label": "원격이라도 기회 풀이 넓은 게 좋다", "score": { "w": 2 } }
      ]
    },

    {
      "id": "g8",
      "axis": "PURPOSE",
      "text": "낙찰받은 물건, 기본 그림은?",
      "options": [
        { "label": "들어가 살거나 세놓아 길게 보유한다", "score": { "r": 2 } },
        { "label": "수리·명도 끝내고 빠르게 되판다", "score": { "f": 2 } }
      ]
    },
    {
      "id": "g9",
      "axis": "PURPOSE",
      "text": "낙찰 후 목표 보유기간에 더 가까운 것은?",
      "options": [
        { "label": "길게 보유하며 현금흐름·시세를 누린다", "score": { "r": 2 } },
        { "label": "단기에 차익 실현하고 자본을 회전한다", "score": { "f": 2 } }
      ]
    },
    {
      "id": "g10",
      "axis": "PURPOSE",
      "text": "명도·수리를 마친 뒤 출구 계획은?",
      "options": [
        { "label": "임대 운영으로 안정적 수익을 가져간다", "score": { "r": 2 } },
        { "label": "매각으로 차익을 실현한다", "score": { "f": 2 } }
      ]
    }
  ],

  "profile_inputs": [
    {
      "id": "fund_size",
      "label": "투자자금",
      "axis": "FUND",
      "text": "경매에 투입할 수 있는 가용 자금 규모는?",
      "options": [
        { "label": "~5천만원", "value": "u50", "score": { "s": 2 } },
        { "label": "5천만~1.5억", "value": "u150", "score": { "s": 1 } },
        { "label": "1.5억~3억", "value": "u300", "score": { "b": 1 } },
        { "label": "3억 이상", "value": "o300", "score": { "b": 2 } }
      ]
    },
    {
      "id": "purpose",
      "label": "투자용도",
      "axis": "PURPOSE",
      "text": "경매로 취득한 물건의 주된 용도는?",
      "options": [
        { "label": "실거주", "value": "reside", "score": { "r": 2 } },
        { "label": "임대수익(장기 보유)", "value": "rent", "score": { "r": 1 } },
        { "label": "단기매각(되팔기)", "value": "flip", "score": { "f": 2 } }
      ]
    },
    {
      "id": "region_pref",
      "label": "투자지역",
      "axis": "REGION",
      "text": "주로 입찰하려는 지역 범위는?",
      "options": [
        { "label": "연고지·내 생활권 위주", "value": "home", "score": { "n": 2 } },
        { "label": "수도권 정도까지", "value": "metro", "score": { "w": 1 } },
        { "label": "전국 어디든", "value": "nation", "score": { "w": 2 } }
      ]
    },
    {
      "id": "ownership",
      "label": "주택보유상황",
      "text": "현재 주택 보유 상황은?",
      "options": [
        { "label": "무주택", "value": "none" },
        { "label": "1주택", "value": "one" },
        { "label": "다주택", "value": "multi" }
      ]
    },
    {
      "id": "experience",
      "label": "경매경험",
      "axis": "DIFFICULTY",
      "text": "지금까지 입찰/낙찰 경험은?",
      "options": [
        { "label": "0~1회 (초보)", "value": "novice", "score": { "c": 1 } },
        { "label": "2~5회 (중급)", "value": "inter", "score": {} },
        { "label": "6회+ (숙련)", "value": "expert", "score": { "x": 1 } }
      ]
    },
    {
      "id": "region_regulated",
      "label": "규제지역 여부",
      "text": "낙찰받으려는 물건 소재지가 규제지역(조정대상지역·투기과열지구·토지거래허가구역)인가요? (대출·세금 규제 판정용, 유형 점수에는 영향 없음)",
      "options": [
        { "label": "규제지역 (서울 전역·경기 일부·신규 지정지 등)", "value": "regulated" },
        { "label": "비규제지역", "value": "normal" },
        { "label": "잘 모르겠다", "value": "unknown" }
      ]
    }
  ],

  "flags": [
    { "when": { "ownership": "multi", "purpose": "flip" }, "level": "warn", "message": "다주택자의 단기매각은 양도세 중과 대상입니다. 보유기간별 세율(1년 미만 70%·2년 미만 60% 등)과 중과 여부를 입찰 전 반드시 검토하세요." },
    { "when": { "ownership": "multi", "purpose": "rent" }, "level": "warn", "message": "다주택자가 추가 보유 시 취득세 중과(조정지역 8~12%)와 종부세 부담이 커집니다. 세후 수익률을 다시 계산하세요." },
    { "when": { "ownership": "multi", "purpose": "reside" }, "level": "warn", "message": "다주택 상태에서의 실거주 취득도 취득세 중과·종부세 영향을 받습니다. 기존 주택 처분 계획과 함께 세무 검토가 필요합니다." },
    { "when": { "ownership": "none", "purpose": "reside" }, "level": "info", "message": "무주택 실거주 취득은 생애최초 취득세 감면·대출 우대 대상일 수 있습니다. 단, 규제지역은 실거주 의무·전입 요건을 확인하세요." },
    { "when": { "experience": "novice", "axis_DIFFICULTY": "x" }, "level": "danger", "message": "경매 초보가 특수물건(유치권·법정지상권·지분 등)에 들어가는 것은 권리분석 실패·명도 분쟁·장기화 위험이 매우 큽니다. 첫 5건은 안전물건으로 경험을 쌓길 강력히 권합니다." },
    { "when": { "axis_FUND": "s", "axis_DIFFICULTY": "x" }, "level": "warn", "message": "소액 자금으로 특수물건을 노리는 조합입니다. 특수물건은 소송·명도에 추가 자금·기간 버퍼가 필요해 자금-난이도가 충돌할 수 있으니 예비비를 확보하세요." },
    { "when": { "type_code": "A-sxwf" }, "level": "danger", "message": "소액·특수·전국·단타는 초보 과욕의 전형적 패턴입니다. 자금·난이도·거리·출구가 모두 어려운 쪽으로 몰려 있어 한 번의 실수가 치명적입니다. 범위를 좁혀 시작하세요." },
    { "when": { "type_code": "A-bcwf" }, "level": "info", "message": "큰 자본을 마진 박한 안전물건 단타에 굴리는 조합입니다. 대액이라면 집중·특수 또는 장기 보유가 자본 효율 면에서 더 합리적일 수 있습니다." },
    { "when": { "region_regulated": "regulated" }, "level": "warn", "message": "경매 낙찰이라도 대출규제는 동일하게 적용됩니다. 경락잔금대출에도 규제지역 LTV(무주택 40% 수준)·다주택 주담대 금지·DSR 40%가 그대로 걸리니, 낙찰가 대비 실제 가용 대출을 보수적으로 잡고 자금계획을 점검하세요. (금융사별 경락대출 취급기준 차이는 확인 필요)" },
    { "when": { "region_regulated": "regulated" }, "level": "info", "message": "경매는 토지거래허가 대상 거래가 아니어서 토허구역의 2년 실거주 의무·갭투자 차단·자금조달계획서 제출 의무가 면제됩니다(일반매매 대비 규제 회피 가능). 다만 이 때문에 규제지역 경매에 수요가 몰려 낙찰가율이 높아지는 쏠림이 나타날 수 있으니 고가낙찰을 경계하세요. (자금출처 소명 등 세무 리스크는 별개)" },
    { "when": { "ownership": "multi", "region_regulated": "regulated" }, "level": "danger", "message": "다주택자가 규제지역 물건을 추가 낙찰하면 경락잔금대출에도 다주택 추가구입 주담대 금지(LTV 0%)가 적용될 수 있습니다. 전액 자기자본 조달을 전제로 입찰가를 잡으세요. (개별 금융사 취급기준은 확인 필요)" },
    { "when": { "ownership": "none", "region_regulated": "regulated" }, "level": "info", "message": "규제지역 무주택 경락대출은 LTV 40% 수준 + 6개월 전입의무가 적용될 수 있습니다. 다만 경매는 토허 실거주 의무 자체는 면제되니, 대출 조건과 실거주 요건을 분리해 확인하세요." },
    { "when": { "region_regulated": "unknown" }, "level": "info", "message": "물건 소재지의 규제지역 여부에 따라 대출 한도가 크게 달라집니다. 입찰 전 국토부 「조정대상지역 및 투기과열지구 지정」 페이지에서 규제 여부를 먼저 확인하세요." }
  ],

